# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# --- Virtual environments -------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Secrets / environment ------------------------------------------------
# Never commit real secrets. Commit .env.example instead.
.env
.env.*
!.env.example

# --- Tooling caches / reports ---------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Project data artifacts (rebuilt via `scrag ingest`) ------------------
data/index/

# --- Model / HuggingFace caches -------------------------------------------
.cache/
*.log

# --- Editors / IDEs -------------------------------------------------------
.idea/
# Ignore local VS Code state but keep the shared interpreter/test config.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp

# --- OS-specific ----------------------------------------------------------
.DS_Store
Thumbs.db
