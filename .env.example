# Copy to `.env` and fill in your key. Any OpenAI-compatible provider works;
# Groq is the default. The key is read from GROQ_API_KEY, OPENAI_API_KEY, or
# SCRAG_LLM_API_KEY (in that order).
GROQ_API_KEY=your_api_key_here

# --- Optional overrides (all use the SCRAG_ prefix) ------------------------
# Point at a different OpenAI-compatible endpoint (OpenAI, vLLM, Ollama, ...):
# SCRAG_LLM_BASE_URL=https://api.openai.com/v1
# SCRAG_GENERATOR_MODEL=llama-3.1-8b-instant
# SCRAG_EVALUATOR_MODEL=llama-3.1-8b-instant
# SCRAG_GUARDRAIL_MODEL=llama-3.1-8b-instant

# Embeddings
# SCRAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# SCRAG_EMBEDDING_DIM=384

# Vector store: numpy (default) or faiss (needs the `faiss` extra)
# SCRAG_VECTOR_BACKEND=numpy
# SCRAG_DOCS_DIR=data/docs
# SCRAG_INDEX_DIR=data/index

# Retrieval / self-correction
# SCRAG_TOP_K=5
# SCRAG_GUARDRAIL_THRESHOLD=0.3
# SCRAG_EVAL_THRESHOLD=0.7
# SCRAG_MAX_SELF_CORRECT_STEPS=2

# API / logging
# SCRAG_API_HOST=0.0.0.0
# SCRAG_API_PORT=8000
# SCRAG_LOG_LEVEL=INFO
# SCRAG_LOG_JSON=false
# Optional shared-secret auth for /query and /ingest (unset = open API).
# When set, send it as `Authorization: Bearer <token>` or `X-API-Key: <token>`.
# SCRAG_API_AUTH_TOKEN=change-me
# Restrict CORS in production (comma/JSON list); defaults to all origins.
# SCRAG_CORS_ALLOW_ORIGINS=["https://your-frontend.example"]
